# Telegram Bot Token (обязательно)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Excel file URL (обязательно)
EXCEL_URL=http://example.com/cashback.xlsx

# Optional HTTP Basic Auth
EXCEL_USER=your_username
EXCEL_PASS=your_password

API_ID=1234567
API_HASH=your_api_hash_here

# Session directory
SESSIONS_DIR=/app/sessions
